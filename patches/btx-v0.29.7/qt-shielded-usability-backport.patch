+[[nodiscard]] std::string ShieldedWhatToTry(const std::string& error)
+{
+    const std::string lower = ToLower(error);
+    std::vector<std::string> tips;
+
+    if (lower.find("insufficient shielded funds") != std::string::npos ||
+        lower.find("no spendable notes selected") != std::string::npos ||
+        lower.find("selected input below total needed") != std::string::npos) {
+        tips.emplace_back("Run getshieldedbalance and z_listunspent to confirm spendable, confirmed shielded notes.");
+        tips.emplace_back("If the balance is fragmented, run z_mergenotes and retry after the merge confirms.");
+        tips.emplace_back("Try a smaller shielded send if the wallet has many small notes.");
+    }
+    if (lower.find("note count exceeds") != std::string::npos ||
+        lower.find("spend limit") != std::string::npos ||
+        lower.find("ring size") != std::string::npos ||
+        lower.find("schedulable") != std::string::npos) {
+        tips.emplace_back("Consolidate shielded notes with z_mergenotes before retrying this send.");
+        tips.emplace_back("Split the payment into smaller sends if consolidation is not enough.");
+    }
+    if (lower.find("fee") != std::string::npos) {
+        tips.emplace_back("Use automatic fee estimation, or retry with a higher explicit fee.");
+    }
+    if (lower.find("anchor") != std::string::npos ||
+        lower.find("sync") != std::string::npos ||
+        lower.find("anonymity pool") != std::string::npos) {
+        tips.emplace_back("Wait for the node and wallet to finish syncing, then retry.");
+    }
+
+    if (tips.empty()) {
+        tips.emplace_back("Check getshieldedbalance and z_listunspent for available confirmed shielded notes.");
+        tips.emplace_back("If the wallet holds many small notes, run z_mergenotes before retrying.");
+        tips.emplace_back("Retry after the node is fully synced.");
+    }
+
+    std::string out = error;
+    out += "\n\nWhat to try:";
+    for (const auto& tip : tips) {
+        out += "\n- ";
+        out += tip;
+    }
+    return out;
+}
+
+[[nodiscard]] std::vector<std::string> ShieldedComplexityWarnings(size_t shielded_input_count,
+                                                                  size_t shielded_output_count,
+                                                                  bool redact_sensitive)
+{
+    std::vector<std::string> warnings;
+    static constexpr size_t WARN_AT_LIVE_SPEND_LIMIT_HEADROOM{2};
+    const size_t live_limit = shielded::v2::MAX_LIVE_DIRECT_SMILE_SPENDS;
+    const bool near_live_limit = shielded_input_count + WARN_AT_LIVE_SPEND_LIMIT_HEADROOM >= live_limit;
+
+    if (near_live_limit) {
+        warnings.emplace_back(redact_sensitive
+            ? "This shielded send is close to the current live note-spend limit. If similar sends fail, consolidate notes with z_mergenotes or split the payment."
+            : strprintf("This shielded send used %u shielded notes, close to the current live limit of %u. If similar sends fail, consolidate notes with z_mergenotes or split the payment.",
+                        static_cast<unsigned int>(shielded_input_count),
+                        static_cast<unsigned int>(live_limit)));
+    } else if (shielded_input_count > 1 && shielded_output_count > 1) {
+        warnings.emplace_back(redact_sensitive
+            ? "This shielded send used multiple notes and created change. Consolidating fragmented notes can make future sends more reliable."
+            : strprintf("This shielded send used %u shielded notes and created %u shielded outputs. Consolidating fragmented notes can make future sends more reliable.",
+                        static_cast<unsigned int>(shielded_input_count),
+                        static_cast<unsigned int>(shielded_output_count)));
+    }
+
+    return warnings;
+}
