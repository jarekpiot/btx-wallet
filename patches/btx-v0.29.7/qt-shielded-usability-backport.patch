+void AddUniqueTip(std::vector<std::string>& tips, std::string tip)
+{
+    if (std::find(tips.begin(), tips.end(), tip) == tips.end()) {
+        tips.emplace_back(std::move(tip));
+    }
+}
+
+void PushStringArray(UniValue& out, const std::string& key, const std::vector<std::string>& values)
+{
+    if (values.empty()) return;
+    UniValue array(UniValue::VARR);
+    for (const auto& value : values) {
+        array.push_back(value);
+    }
+    out.pushKV(key, std::move(array));
+}
+
+[[nodiscard]] std::string ShieldedWhatToTry(const std::string& error)
+{
+    const std::string lower = ToLower(error);
+    std::vector<std::string> tips;
+
+    if (lower.find("insufficient shielded funds") != std::string::npos ||
+        lower.find("no spendable notes selected") != std::string::npos ||
+        lower.find("selected input below total needed") != std::string::npos) {
+        AddUniqueTip(tips, "Run z_getbalance and z_listunspent to confirm spendable, confirmed shielded notes.");
+        AddUniqueTip(tips, "If the balance is fragmented, run z_mergenotes and retry after the merge confirms.");
+        AddUniqueTip(tips, "Try a smaller shielded send if the wallet has many small notes.");
+    }
+    if (lower.find("note count exceeds") != std::string::npos ||
+        lower.find("spend limit") != std::string::npos ||
+        lower.find("ring size") != std::string::npos ||
+        lower.find("schedulable") != std::string::npos) {
+        AddUniqueTip(tips, "Consolidate shielded notes with z_mergenotes before retrying this send.");
+        AddUniqueTip(tips, "Split the payment into smaller sends if consolidation is not enough.");
+    }
+    if (lower.find("fee") != std::string::npos) {
+        AddUniqueTip(tips, "Use automatic fee estimation, or retry with a higher explicit fee.");
+    }
+    if (lower.find("anchor") != std::string::npos ||
+        lower.find("sync") != std::string::npos ||
+        lower.find("anonymity pool") != std::string::npos) {
+        AddUniqueTip(tips, "Wait for the node and wallet to finish syncing, then retry.");
+    }
+    if (lower.find("locked") != std::string::npos ||
+        lower.find("unlock") != std::string::npos ||
+        lower.find("encrypted") != std::string::npos) {
+        AddUniqueTip(tips, "Unlock the encrypted wallet only for the time needed to complete the operation.");
+    }
+    if (lower.find("invalid shielded destination") != std::string::npos ||
+        lower.find("invalid address") != std::string::npos) {
+        AddUniqueTip(tips, "Check that the destination is a BTX shielded address and send a small test amount first.");
+    }
+    if (lower.find("amount must be") != std::string::npos ||
+        lower.find("amount + fee") != std::string::npos) {
+        AddUniqueTip(tips, "Check the amount, leave room for fees, and avoid sending the entire shielded balance at once.");
+    }
+
+    if (tips.empty()) {
+        AddUniqueTip(tips, "Check z_getbalance and z_listunspent for available confirmed shielded notes.");
+        AddUniqueTip(tips, "If the wallet holds many small notes, run z_mergenotes before retrying.");
+        AddUniqueTip(tips, "Retry after the node is fully synced.");
+    }
+
+    std::string out = error;
+    out += "\n\nWhat to try:";
+    for (const auto& tip : tips) {
+        out += "\n- ";
+        out += tip;
+    }
+    return out;
+}
+
+[[nodiscard]] std::string ShieldedNoteHealthLabel(size_t spendable_note_count,
+                                                  bool scan_incomplete,
+                                                  bool locked_state_incomplete)
+{
+    if (scan_incomplete || locked_state_incomplete) return "limited_visibility";
+
+    const size_t live_limit = shielded::v2::MAX_LIVE_DIRECT_SMILE_SPENDS;
+    if (spendable_note_count + 2 >= live_limit) return "high_fragmentation";
+    if (spendable_note_count >= live_limit / 2) return "moderate_fragmentation";
+    return "normal";
+}
+
+[[nodiscard]] std::vector<std::string> ShieldedNoteHealthGuidance(size_t spendable_note_count,
+                                                                  bool scan_incomplete,
+                                                                  bool locked_state_incomplete)
+{
+    std::vector<std::string> guidance;
+
+    if (scan_incomplete) {
+        AddUniqueTip(guidance, "Shielded scanning is incomplete. Finish syncing or rescan before relying on this balance.");
+    }
+    if (locked_state_incomplete) {
+        AddUniqueTip(guidance, "Unlock the wallet briefly and refresh if shielded accounting was loaded from locked fallback state.");
+    }
+
+    const size_t live_limit = shielded::v2::MAX_LIVE_DIRECT_SMILE_SPENDS;
+    if (spendable_note_count == 0) {
+        AddUniqueTip(guidance, "No confirmed spendable shielded notes are currently available.");
+    } else if (spendable_note_count + 2 >= live_limit) {
+        AddUniqueTip(guidance, strprintf("High shielded note count: %u spendable notes is close to the live spend limit of %u. Run z_mergenotes before large sends.",
+                                         static_cast<unsigned int>(spendable_note_count),
+                                         static_cast<unsigned int>(live_limit)));
+        AddUniqueTip(guidance, "If consolidation still leaves many notes, split large payments into smaller sends.");
+    } else if (spendable_note_count >= live_limit / 2) {
+        AddUniqueTip(guidance, "Moderate shielded fragmentation: consolidation is recommended before important or large payments.");
+    } else {
+        AddUniqueTip(guidance, "Shielded note count looks manageable for normal sends.");
+    }
+
+    return guidance;
+}
+
+[[nodiscard]] std::vector<std::string> ShieldedComplexityWarnings(size_t shielded_input_count,
+                                                                  size_t shielded_output_count,
+                                                                  bool redact_sensitive)
+{
+    std::vector<std::string> warnings;
+    if (redact_sensitive) return warnings;
+
+    static constexpr size_t WARN_AT_LIVE_SPEND_LIMIT_HEADROOM{2};
+    const size_t live_limit = shielded::v2::MAX_LIVE_DIRECT_SMILE_SPENDS;
+    const bool near_live_limit = shielded_input_count + WARN_AT_LIVE_SPEND_LIMIT_HEADROOM >= live_limit;
+
+    if (near_live_limit) {
+        warnings.emplace_back(strprintf("This shielded send used %u shielded notes, close to the current live limit of %u. If similar sends fail, consolidate notes with z_mergenotes or split the payment.",
+                        static_cast<unsigned int>(shielded_input_count),
+                        static_cast<unsigned int>(live_limit)));
+    } else if (shielded_input_count >= live_limit / 2) {
+        warnings.emplace_back(strprintf("This shielded send used %u shielded notes. Consider z_mergenotes before future large sends to reduce fragmentation and retry risk.",
+                        static_cast<unsigned int>(shielded_input_count)));
+    } else if (shielded_input_count > 1 && shielded_output_count > 1) {
+        warnings.emplace_back(strprintf("This shielded send used %u shielded notes and created %u shielded outputs. Consolidating fragmented notes can make future sends more reliable.",
+                        static_cast<unsigned int>(shielded_input_count),
+                        static_cast<unsigned int>(shielded_output_count)));
+    }
+
+    return warnings;
+}
+
+[[nodiscard]] std::vector<std::string> ShieldedMergeNextSteps(size_t merged_count,
+                                                              size_t remaining_spendable_notes)
+{
+    std::vector<std::string> steps;
+    AddUniqueTip(steps, "Wait for the merge transaction to confirm before retrying a large shielded send.");
+
+    const size_t live_limit = shielded::v2::MAX_LIVE_DIRECT_SMILE_SPENDS;
+    if (remaining_spendable_notes + 2 >= live_limit) {
+        AddUniqueTip(steps, "Many spendable notes remain. Run z_mergenotes again after confirmation, or split the original payment.");
+    } else if (remaining_spendable_notes >= live_limit / 2) {
+        AddUniqueTip(steps, "Some fragmentation remains. Consider another merge before a large or important payment.");
+    } else if (merged_count > 1) {
+        AddUniqueTip(steps, "After confirmation, refresh z_getbalance and retry the original shielded send.");
+    }
+
+    return steps;
+}
