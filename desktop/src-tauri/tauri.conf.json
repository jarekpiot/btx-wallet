{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BTX Wallet Light",
  "version": "0.2.0",
  "identifier": "dev.btx.wallet.light",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "BTX Wallet Light",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 660,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Lightweight BTX desktop wallet",
    "longDescription": "A lightweight BTX desktop wallet that delegates signing, key handling, and shielded transaction construction to the official audited BTX core through JSON-RPC."
  }
}
